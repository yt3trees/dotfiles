{
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File $HOME/.claude/hooks/cc-toast.ps1 -Event Notification -SilentWhenFocused"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File $HOME/.claude/hooks/cc-toast.ps1 -Event Stop -SilentWhenFocused"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell.exe -ExecutionPolicy Bypass -File $HOME/.claude/statusline.ps1"
  },
  "language": "Japanese"
}
